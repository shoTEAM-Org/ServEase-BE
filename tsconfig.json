{
  "compilerOptions": {
    "module": "nodenext",
    "moduleResolution": "nodenext",
    "resolvePackageJsonExports": true,
    "esModuleInterop": true,
    "isolatedModules": true,
    "declaration": true,
    "removeComments": true,
    "emitDecoratorMetadata": true,
    "experimentalDecorators": true,
    "allowSyntheticDefaultImports": true,
    "target": "ES2023",
    "sourceMap": true,
    "outDir": "./dist",
    "baseUrl": "./",
    "incremental": true,
    "skipLibCheck": true,
    "strictNullChecks": true,
    "forceConsistentCasingInFileNames": true,
    "noImplicitAny": false,
    "strictBindCallApply": false,
    "noFallthroughCasesInSwitch": false,
    "types": ["node", "express", "multer", "jest"],
    "paths": {
      "@app/common": ["libs/common/src"],
      "@app/common/*": ["libs/common/src/*"],
      "@app/database": ["libs/database/src"],
      "@app/database/*": ["libs/database/src/*"],
      "@app/auth-service": ["apps/auth-service/src"],
      "@app/auth-service/*": ["apps/auth-service/src/*"],
      "@app/booking-service": ["apps/booking-service/src"],
      "@app/booking-service/*": ["apps/booking-service/src/*"],
      "@app/chat-service": ["apps/chat-service/src"],
      "@app/chat-service/*": ["apps/chat-service/src/*"],
      "@app/payment-service": ["apps/payment-service/src"],
      "@app/payment-service/*": ["apps/payment-service/src/*"],
      "@app/provider-service": ["apps/provider-service/src"],
      "@app/provider-service/*": ["apps/provider-service/src/*"],
      "@app/customer-service": ["apps/customer-service/src"],
      "@app/customer-service/*": ["apps/customer-service/src/*"],
      "@app/admin-service": ["apps/admin-service/src"],
      "@app/admin-service/*": ["apps/admin-service/src/*"],
      "@app/catalog-service": ["apps/catalog-service/src"],
      "@app/catalog-service/*": ["apps/catalog-service/src/*"],
      "@app/notifications-service": ["apps/notifications-service/src"],
      "@app/notifications-service/*": ["apps/notifications-service/src/*"],
      "@app/support-service": ["apps/support-service/src"],
      "@app/support-service/*": ["apps/support-service/src/*"]
    }
  },
  "include": ["src/**/*", "apps/**/*", "libs/**/*"],
  "exclude": [
    "node_modules", "dist", "dist-new",
    "src/modules",
    "libs/common/src/kafka",
    "libs/common/src/interceptors",
    "libs/common/src/mock-data"
  ]
}
