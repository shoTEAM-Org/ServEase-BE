# ============================================================
# ServEase Backend — Environment Variables
# Copy this file to .env and fill in your values.
# ============================================================

# ------------------------------------------------------------
# SUPABASE (Required — all services)
# ------------------------------------------------------------
SUPABASE_URL=https://your-project-id.supabase.co
SUPABASE_SECRET_KEY=your-service-role-secret-key

# ------------------------------------------------------------
# KAFKA (Optional — defaults shown)
# ------------------------------------------------------------
KAFKA_BROKER=localhost:9092

# How long to wait for the consumer group to be ready on startup (ms)
KAFKA_GROUP_READINESS_DELAY_MS=12000

# ------------------------------------------------------------
# GATEWAY (Optional — defaults shown)
# ------------------------------------------------------------
PORT=5000

# HTTP request timeout on the gateway (ms)
GATEWAY_REQUEST_TIMEOUT_MS=30000

# Kafka RPC timeouts (ms)
KAFKA_REQUEST_TIMEOUT_MS=30000
KAFKA_CHAT_REQUEST_TIMEOUT_MS=30000

# Inter-service Kafka RPC settings
KAFKA_INTERSERVICE_TIMEOUT_MS=10000
KAFKA_INTERSERVICE_RETRIES=3
KAFKA_INTERSERVICE_RETRY_DELAY_MS=100

# ------------------------------------------------------------
# EMAIL SERVICE (Optional — emails are skipped if not set)
# ------------------------------------------------------------
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
# Set to 'true' for port 465 (implicit TLS), leave 'false' for STARTTLS
SMTP_SECURE=false
SMTP_USER=your-email@gmail.com
# For Gmail, use an App Password (not your account password)
SMTP_PASS=your-app-password
EMAIL_FROM=no-reply@servease.app

# ------------------------------------------------------------
# TRIBE CLIENT / @implementsprint/sdk (Required for geo & OTP)
# Credentials are issued by the implementsprint platform.
# ------------------------------------------------------------
TRIBE_GATEWAY_URL=https://your-gateway.implementsprint.io
TRIBE_ID=your-tribe-id
TRIBE_SECRET=your-tribe-secret

# ------------------------------------------------------------
# FEATURE FLAGS (Optional — defaults shown)
# ------------------------------------------------------------
# Allow providers without completed KYC to accept bookings
ALLOW_UNVERIFIED_PROVIDER_BOOKINGS=false

# ------------------------------------------------------------
# EXTERNAL APIS (Optional)
# ------------------------------------------------------------
# Real-time fuel price feed used by the pricing engine
# If unset, the engine uses a cached/default fuel baseline
SERVEASE_FUEL_PRICE_URL=

# ------------------------------------------------------------
# STRICT SERVICE SCOPE (Optional — advanced)
# Set to 'true' to require per-service Supabase credentials.
# When enabled, each service reads its own scoped URL and key
# instead of the shared SUPABASE_URL / SUPABASE_SECRET_KEY.
# ------------------------------------------------------------
SUPABASE_STRICT_SERVICE_SCOPE=false

# If SUPABASE_STRICT_SERVICE_SCOPE=true, uncomment and fill these:
# GATEWAY_SUPABASE_URL=
# GATEWAY_SUPABASE_SECRET_KEY=
# AUTH_SERVICE_SUPABASE_URL=
# AUTH_SERVICE_SUPABASE_SECRET_KEY=
# BOOKING_SERVICE_SUPABASE_URL=
# BOOKING_SERVICE_SUPABASE_SECRET_KEY=
# CATALOG_SERVICE_SUPABASE_URL=
# CATALOG_SERVICE_SUPABASE_SECRET_KEY=
# CHAT_SERVICE_SUPABASE_URL=
# CHAT_SERVICE_SUPABASE_SECRET_KEY=
# CUSTOMER_SERVICE_SUPABASE_URL=
# CUSTOMER_SERVICE_SUPABASE_SECRET_KEY=
# EMAIL_SERVICE_SUPABASE_URL=
# EMAIL_SERVICE_SUPABASE_SECRET_KEY=
# NOTIFICATIONS_SERVICE_SUPABASE_URL=
# NOTIFICATIONS_SERVICE_SUPABASE_SECRET_KEY=
# PAYMENT_SERVICE_SUPABASE_URL=
# PAYMENT_SERVICE_SUPABASE_SECRET_KEY=
# PROVIDER_SERVICE_SUPABASE_URL=
# PROVIDER_SERVICE_SUPABASE_SECRET_KEY=
# SUPPORT_SERVICE_SUPABASE_URL=
# SUPPORT_SERVICE_SUPABASE_SECRET_KEY=
# TRUST_SERVICE_SUPABASE_URL=
# TRUST_SERVICE_SUPABASE_SECRET_KEY=
# ADMIN_SERVICE_SUPABASE_URL=
# ADMIN_SERVICE_SUPABASE_SECRET_KEY=
