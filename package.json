{
  "name": "servease-be-api",
  "version": "0.0.1",
  "description": "",
  "author": "",
  "private": true,
  "license": "UNLICENSED",
  "scripts": {
    "build": "nest build",
    "format": "prettier --write \"src/**/*.ts\" \"libs/**/*.ts\"",
    "start:gateway": "nest start",
    "start:gateway:dev": "nest start --watch --preserveWatchOutput",
    "start:gateway:debug": "nest start --debug --watch",
    "start:gateway:prod": "node dist/src/main.js",
    "start:auth": "nest start auth-service --watch --preserveWatchOutput",
    "start:booking": "nest start booking-service --watch --preserveWatchOutput",
    "start:chat": "nest start chat-service --watch --preserveWatchOutput",
    "start:payment": "nest start payment-service --watch --preserveWatchOutput",
    "start:provider": "nest start provider-service --watch --preserveWatchOutput",
    "start:customer": "nest start customer-service --watch --preserveWatchOutput",
    "start:admin": "nest start admin-service --watch --preserveWatchOutput",
    "start:catalog": "nest start catalog-service --watch --preserveWatchOutput",
    "start:notifications": "nest start notifications-service --watch --preserveWatchOutput",
    "start:support": "nest start support-service --watch --preserveWatchOutput",
    "start:trust": "nest start trust-service --watch --preserveWatchOutput",
    "start:auth:prod": "node dist/apps/auth-service/src/main.js",
    "start:booking:prod": "node dist/apps/booking-service/src/main.js",
    "start:chat:prod": "node dist/apps/chat-service/src/main.js",
    "start:payment:prod": "node dist/apps/payment-service/src/main.js",
    "start:provider:prod": "node dist/apps/provider-service/src/main.js",
    "start:customer:prod": "node dist/apps/customer-service/src/main.js",
    "start:admin:prod": "node dist/apps/admin-service/src/main.js",
    "start:catalog:prod": "node dist/apps/catalog-service/src/main.js",
    "start:notifications:prod": "node dist/apps/notifications-service/src/main.js",
    "start:support:prod": "node dist/apps/support-service/src/main.js",
    "start:trust:prod": "node dist/apps/trust-service/src/main.js",
    "start:all": "concurrently \"npm:start:gateway\" \"npm:start:auth:prod\" \"npm:start:booking:prod\" \"npm:start:chat:prod\" \"npm:start:payment:prod\" \"npm:start:provider:prod\" \"npm:start:customer:prod\" \"npm:start:admin:prod\" \"npm:start:catalog:prod\" \"npm:start:notifications:prod\" \"npm:start:support:prod\" \"npm:start:trust:prod\"",
    "start:dev:all": "concurrently -n gateway,auth,booking,chat,payment,provider,customer,admin,catalog,notify,support,trust -c blue,green,yellow,cyan,magenta,red,white,gray,blue,green,yellow,magenta \"npm:start:gateway:dev\" \"npm:start:auth\" \"npm:start:booking\" \"npm:start:chat\" \"npm:start:payment\" \"npm:start:provider\" \"npm:start:customer\" \"npm:start:admin\" \"npm:start:catalog\" \"npm:start:notifications\" \"npm:start:support\" \"npm:start:trust\"",
    "infra:up": "docker compose up -d kafka",
    "infra:down": "docker compose down",
    "infra:wait": "docker compose exec -T kafka sh -c \"until /opt/kafka/bin/kafka-broker-api-versions.sh --bootstrap-server localhost:9092 >/dev/null 2>&1; do sleep 1; done\"",
    "dev": "npm run infra:up && npm run infra:wait && npm run start:dev:all",
    "lint": "eslint \"src/**/*.ts\" \"libs/**/*.ts\" --fix",
    "test": "jest",
    "test:watch": "jest --watch",
    "test:cov": "jest --coverage",
    "test:debug": "node --inspect-brk -r tsconfig-paths/register -r ts-node/register node_modules/.bin/jest --runInBand",
    "test:e2e": "jest --config ./test/jest-e2e.json"
  },
  "dependencies": {
    "@nestjs/common": "^11.0.1",
    "@nestjs/config": "^4.0.3",
    "@nestjs/core": "^11.0.1",
    "@nestjs/event-emitter": "^3.0.1",
    "@nestjs/microservices": "^11.0.1",
    "@nestjs/passport": "^11.0.5",
    "@nestjs/platform-express": "^11.0.1",
    "@supabase/supabase-js": "^2.98.0",
    "bcrypt": "^6.0.0",
    "class-transformer": "^0.5.1",
    "class-validator": "^0.15.1",
    "jsonwebtoken": "^9.0.3",
    "nestjs": "^0.0.1",
    "passport": "^0.7.0",
    "passport-google-oauth20": "^2.0.0",
    "reflect-metadata": "^0.2.2",
    "concurrently": "^9.0.0",
    "kafkajs": "^2.2.4",
    "rxjs": "^7.8.1",
    "uuid": "^13.0.0"
  },
  "devDependencies": {
    "@eslint/eslintrc": "^3.2.0",
    "@eslint/js": "^9.18.0",
    "@nestjs/cli": "^11.0.16",
    "@nestjs/schematics": "^11.0.9",
    "@nestjs/testing": "^11.0.1",
    "@types/express": "^5.0.0",
    "@types/jest": "^30.0.0",
    "@types/multer": "^2.1.0",
    "@types/node": "^22.10.7",
    "@types/passport-google-oauth20": "^2.0.17",
    "@types/supertest": "^6.0.2",
    "eslint": "^9.18.0",
    "eslint-config-prettier": "^10.0.1",
    "eslint-plugin-prettier": "^5.2.2",
    "globals": "^16.0.0",
    "jest": "^30.0.0",
    "prettier": "^3.4.2",
    "source-map-support": "^0.5.21",
    "supertest": "^7.0.0",
    "ts-jest": "^29.2.5",
    "ts-loader": "^9.2.1",
    "ts-node": "^10.9.2",
    "tsconfig-paths": "^4.2.0",
    "typescript": "^5.7.3",
    "typescript-eslint": "^8.20.0"
  },
  "jest": {
    "moduleFileExtensions": [
      "js",
      "json",
      "ts"
    ],
    "rootDir": ".",
    "roots": [
      "<rootDir>/src/",
      "<rootDir>/libs/"
    ],
    "testRegex": ".*\\.spec\\.ts$",
    "transform": {
      "^.+\\.(t|j)s$": "ts-jest"
    },
    "collectCoverageFrom": [
      "**/*.(t|j)s"
    ],
    "coverageDirectory": "../coverage",
    "testEnvironment": "node"
  },
  "overrides": {
    "picomatch": "^4.0.4"
  }
}
